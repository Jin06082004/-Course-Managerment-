# MoMo Payment Configuration - Development/Sandbox
# Lấy các giá trị này từ https://business.momo.vn/portal
# Nhân bản file này thành .env và điền giá trị thật

# MoMo Dev/Sandbox Keys
MOMO_DEV_PARTNER_CODE=MOMO_DEV_PARTNER_CODE_TỪ_BUSINESS_PORTAL
MOMO_DEV_ACCESS_KEY=MOMO_DEV_ACCESS_KEY_TỪ_BUSINESS_PORTAL
MOMO_DEV_SECRET_KEY=MOMO_DEV_SECRET_KEY_TỪ_BUSINESS_PORTAL

# MoMo Dev/Sandbox Endpoint (mặc định test payment)
MOMO_DEV_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# MoMo Callback URLs (dev)
MOMO_DEV_RETURN_URL=http://localhost:8080/api/payment/momo-return
MOMO_DEV_NOTIFY_URL=http://localhost:8080/api/payment/momo-notify

# Optional: MoMo Production Keys (nếu cần)
# MOMO_PARTNER_CODE=YOUR_PROD_PARTNER_CODE
# MOMO_ACCESS_KEY=YOUR_PROD_ACCESS_KEY
# MOMO_SECRET_KEY=YOUR_PROD_SECRET_KEY
# MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/course_managerment_?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=123456

# JWT
JWT_SECRET=your_jwt_secret_key_minimum_512_bits_length_for_hs512_algorithm_security_must_be_at_least_64_characters_long

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
